rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ─── User namespace ────────────────────────────────────────────────────────
    // All user data lives under users/{uid}/...
    // Only the authenticated user (including anonymous) can read/write their own data.

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Profile
      match /profile/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Exercises (predefined + custom)
      match /exercises/{exerciseId} {
        allow read, write: if isOwner(uid);
      }

      // Routines
      match /routines/{routineId} {
        allow read, write: if isOwner(uid);
      }

      // Routine exercise configuration
      match /routineExercises/{reId} {
        allow read, write: if isOwner(uid);
      }

      // Weekly schedule template
      match /scheduleTemplate/{templateId} {
        allow read, write: if isOwner(uid);
      }

      // Workout sessions
      match /workoutSessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }

      // Workout entries (per session per exercise)
      match /workoutEntries/{entryId} {
        allow read, write: if isOwner(uid);
      }

      // Set entries (individual sets)
      match /setEntries/{setId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
